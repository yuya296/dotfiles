# ~/.zshrc
# Interactive shell: source split config files.

ZSH_CONFIG_DIR="$ZDOTDIR/zsh.d"
for zsh_config_file in "${ZSH_CONFIG_DIR}"/*.zsh(N); do
  source "${zsh_config_file}"
done


# BEGIN opam configuration
# This is useful if you're using opam as it adds:
#   - the correct directories to the PATH
#   - auto-completion for the opam binary
# This section can be safely removed at any time if needed.
[[ ! -r '/Users/yuya/.opam/opam-init/init.zsh' ]] || source '/Users/yuya/.opam/opam-init/init.zsh' > /dev/null 2> /dev/null
# END opam configuration
